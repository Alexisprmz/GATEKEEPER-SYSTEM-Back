{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2020"],
    "target": "ES2020",
    "moduleResolution": "Node16",
    "module": "Node16",
    "strict": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  },
  "include": ["src/**/*.ts"]
}